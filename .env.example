# Clé API OpenRouter (obligatoire)
OPENROUTER_API_KEY=sk-or-v1-...

# Modèle LLM à utiliser (optionnel, par défaut: google/gemini-3.1-flash-lite)
MODEL_NAME=google/gemini-3.1-flash-lite

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=https://delcoco95.github.io,http://localhost:8000
